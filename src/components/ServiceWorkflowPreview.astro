---
const Props = Astro.props as {
  title?: string;
  serviceBadge?: string;
  scenarioCards?: Array<{ k: string; v: string }>;
  ctaText?: string;
  onRequestHref?: string;
  whatsappHref?: string;
};

const {
  title = 'Workflow preview (what you’ll get)',
  serviceBadge,
  scenarioCards = [
    { k: 'Modules', v: 'Screens & ledger/data mapping matched to your real operations.' },
    { k: 'Role rights', v: 'Operator/supervisor patterns with report-ready access controls.' },
    { k: 'UAT + delivery', v: 'Hand-delivered with UAT so outputs are correct for daily use.' },
  ],
  ctaText = 'Request this service →',
  onRequestHref = '/contact',
  whatsappHref = 'https://wa.me/923001234567',
} = Props;
---
<section class="mt-10">
  <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas-soft)] shadow-lvl3 p-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
          {serviceBadge ?? 'DELIVERY PREVIEW'}
        </div>
        <h3 class="display-md mt-2">{title}</h3>
        <p class="mt-3 text-[14px] leading-[20px] text-[var(--body)] max-w-[72ch]">
          A quick snapshot of the flow we deliver—so you can confidently scope the next step.
        </p>
      </div>

      <div class="flex flex-col sm:items-end gap-3 shrink-0">
        <a
          href={onRequestHref}
          class="inline-flex items-center justify-center h-11 px-6 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-90 transition"
        >
          {ctaText}
        </a>
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center h-11 px-6 rounded-[var(--radius-pill)] bg-[var(--canvas)] text-[var(--ink)] text-[14px] font-semibold border border-[var(--hairline)] hover:bg-[var(--canvas-soft-2)] transition"
        >
          WhatsApp quick chat ↗
        </a>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
      {scenarioCards.map((c) => (
        <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas)] p-5" key={c.k}>
          <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
            {c.k}
          </div>
          <div class="mt-2 text-[14px] leading-[20px] font-semibold text-[var(--ink)]">
            {c.v}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
