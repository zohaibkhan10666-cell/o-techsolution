---
interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  class: className = '',
  width = 800,
  height = 450,
  loading = 'lazy',
} = Astro.props;
---

<div class={`image-reveal overflow-hidden rounded-[var(--radius-lg)] relative ${className}`}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    referrerpolicy="no-referrer"
    crossorigin="anonymous"
    class="w-full h-full object-cover transition-transform duration-500 ease-out hover:scale-105"
    onerror={`this.onerror=null; this.style.display='none'; const parent=this.parentElement; parent.classList.add('image-fallback'); parent.setAttribute('data-image-fallback','true'); const label=parent.querySelector('[data-image-fallback-label]'); if(!label){ const div=document.createElement('div'); div.setAttribute('data-image-fallback-label','true'); div.style.position='absolute'; div.style.inset='0'; div.style.display='flex'; div.style.alignItems='center'; div.style.justifyContent='center'; div.style.padding='12px'; div.style.background='linear-gradient(135deg, var(--canvas-soft) 0%, var(--canvas-soft-2) 100%)'; div.style.color='var(--body)'; div.style.textAlign='center'; div.style.fontSize='12px'; div.style.fontFamily='var(--font-mono)'; div.innerText='Image unavailable (404). Please refresh.'; parent.appendChild(div);} `}
  />
</div>
