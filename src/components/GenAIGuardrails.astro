---
const Props = Astro.props as {
  title?: string;
  bullets?: Array<{ k: string; v: string }>;
  note?: string;
};

const {
  title = 'GEN-AI (guardrails included)',
  bullets = [
    { k: 'Human-in-the-loop', v: 'AI assists decisions, but final actions stay under your approval and workflow rules.' },
    { k: 'Rules-aware outputs', v: 'We generate drafts aligned with your ledger/data logic—consistent formatting and correctness-first.' },
    { k: 'No silent changes', v: 'AI suggestions never overwrite core data without validation steps and traceable review.' },
  ],
  note = 'This keeps automation helpful—without breaking reliability or ERP/accounting correctness.',
} = Props;
---

<section class="mt-10">
  <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas-soft)] shadow-lvl3 p-6">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <div>
        <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
          GEN-AI
        </div>
        <h3 class="display-md mt-2">{title}</h3>
      </div>
      <span class="inline-flex items-center justify-center h-9 px-4 rounded-full border border-[var(--hairline)] bg-[var(--canvas)] text-[13px] font-semibold text-[var(--ink)]" style="font-family: var(--font-mono);">
        Safe automation
      </span>
    </div>

    <p class="mt-3 text-[14px] leading-[20px] text-[var(--body)] max-w-[80ch]">
      {note}
    </p>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
      {bullets.map((b) => (
        <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas)] p-5" key={b.k}>
          <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
            {b.k}
          </div>
          <div class="mt-2 text-[14px] leading-[20px] font-semibold text-[var(--ink)]">
            {b.v}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-6 rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-5">
      <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
        Where GEN-AI helps
      </div>
      <ul class="mt-3 space-y-2 text-[14px] text-[var(--body)]">
        {[
          'Summarize workflows and generate guided next steps',
          'Assist report drafting while preserving ledger correctness',
          'Validate inputs and highlight inconsistencies for review',
        ].map((x) => (
          <li class="flex gap-3 items-start" key={x}>
            <span class="mt-1 inline-flex w-5 h-5 items-center justify-center rounded-full bg-[var(--canvas-soft)] border border-[var(--hairline)] text-[11px]">
              ✓
            </span>
            <span>{x}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
