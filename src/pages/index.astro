          <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-to-tr from-[#007cf0]/5 to-transparent rounded-tr-full pointer-events-none"></div>
          
          <div class="relative flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
              <div class="inline-flex items-center gap-2">
                <span class="inline-flex w-2.5 h-2.5 rounded-full bg-[var(--color-accent)] live-indicator-pulse" />
