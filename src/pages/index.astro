            <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-5">
              <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">MODULE PREVIEW</div>
              <div class="mt-3 rounded-[var(--radius-md)] bg-[var(--primary)] text-[var(--on-primary)] p-4 shadow-lvl2">
                <div class="text-[12px] opacity-80" style="font-family: var(--font-mono);">KACHI PARCHI • READ-ONLY</div>
                <div class="mt-2 grid grid-cols-3 gap-2 text-[12px]" style="font-family: var(--font-mono);">
                  <div class="rounded bg-white/5 px-2 py-1 border border-white/10">DOC# 01</div>
                  <div class="rounded bg-white/5 px-2 py-1 border border-white/10">AMT 24,500</div>
                  <div class="rounded bg-white/5 px-2 py-1 border border-white/10">13-Jun-26</div>
                </div>
                <div class="mt-3 h-24 rounded bg-white/5 border border-white/10 flex items-center justify-center shimmer">
                  <span class="text-[12px] opacity-50" style="font-family: var(--font-mono);">LEDGER VIEW (MOCK)</span>
                </div>
              </div>
            </div>

            <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-5">
              <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">WHY THIS MATTERS</div>
