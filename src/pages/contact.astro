---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import OptimizedImage from '../components/OptimizedImage.astro';

const services = [
  { label: 'Web Development (MERN, MEAN, Next)', value: 'web-development' },
  { label: 'Oracle PL/SQL Database Software (Finance)', value: 'oracle-finance' },
  { label: 'Weaving Software (Textile ERP)', value: 'weaving' },
  { label: 'Finance & Accounts Management', value: 'finance-accounts' },
  { label: 'Travel Agency Software', value: 'travel-agency-erp' },
  { label: 'School & Hospital Management System', value: 'school-hospital-management' },
];

const faqs = [
  { q: 'How long does a typical project take?', a: '2-8 weeks depending on scope. We align on timeline during discovery.' },
  { q: 'Do you provide ongoing support?', a: 'Yes. Every delivery includes post-launch support and iteration cycles.' },
  { q: 'Can I see a demo first?', a: 'Absolutely. We have live demo sandboxes for most modules.' },
];
---

<Layout title="O-Tech Solutions | Contact" description="Project inquiry form for O-Tech Solutions.">
  <!-- HERO -->
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <!-- Hero Image -->
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 overflow-hidden mb-8">
        <div class="relative h-48 overflow-hidden">
          <OptimizedImage
            src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&h=400&fit=crop"
            alt="Contact O-Tech Solutions"
            loading="eager"
            width={1400}
            height={400}
            class="w-full h-full"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[var(--canvas)] via-transparent to-[var(--canvas)]"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">CONTACT</div>
              <h1 class="display-xl mt-2 text-[var(--ink)]">Tell us your module. We'll hand-deliver a plan.</h1>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-5">
          <ScrollReveal>
            <p class="text-[16px] leading-[24px] text-[var(--body)]">
              Choose the service and share your requirements. We typically respond within 24 hours with a scoped plan.
            </p>
          </ScrollReveal>

          <ScrollReveal delay={100}>
            <div class="mt-6 rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">DIRECT</div>
              <div class="mt-3 flex flex-col gap-3">
                <a href="tel:+900000000000" class="group inline-flex items-center justify-between rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-4 py-3 hover:bg-[var(--canvas-soft-2)] transition-all duration-200 hover:shadow-lvl2">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center group-hover:bg-[var(--color-accent)] transition-colors duration-300">
                      <svg class="w-5 h-5 text-[var(--color-accent)] group-hover:text-white transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .07h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                      </svg>
                    </div>
                    <span class="text-[14px] font-semibold">Phone</span>
                  </div>
                  <span class="text-[14px]" style="font-family: var(--font-mono); color: var(--body);">+91 ••••••••••</span>
                </a>

                <a href="#" class="group inline-flex items-center justify-between rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-4 py-3 hover:bg-[var(--canvas-soft-2)] transition-all duration-200 hover:shadow-lvl2">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#25D366]/10 flex items-center justify-center group-hover:bg-[#25D366] transition-colors duration-300">
                      <svg class="w-5 h-5 text-[#25D366] group-hover:text-white transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                      </svg>
                    </div>
                    <span class="text-[14px] font-semibold">WhatsApp</span>
                  </div>
                  <span class="text-[14px]" style="font-family: var(--font-mono); color: var(--body);">Chat</span>
                </a>

                <a href="/demo" class="group inline-flex items-center justify-between rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-4 py-3 hover:bg-[var(--canvas-soft-2)] transition-all duration-200 hover:shadow-lvl2">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#007cf0]/10 flex items-center justify-center group-hover:bg-[#007cf0] transition-colors duration-300">
                      <svg class="w-5 h-5 text-[#007cf0] group-hover:text-white transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="5 3 19 12 5 21 5 3"/>
                      </svg>
                    </div>
                    <span class="text-[14px] font-semibold">View demo</span>
                  </div>
                  <span class="text-[14px]" style="font-family: var(--font-mono); color: var(--body);">Sandbox</span>
                </a>
              </div>
            </div>
          </ScrollReveal>

          <!-- FAQ -->
          <ScrollReveal delay={200}>
            <div class="mt-6 rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">FAQ</div>
              <div class="mt-4 space-y-4">
                {faqs.map((f) => (
                  <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-4">
                    <div class="text-[14px] font-semibold text-[var(--ink)]">{f.q}</div>
                    <div class="mt-2 text-[13px] leading-[20px] text-[var(--body)]">{f.a}</div>
                  </div>
                ))}
              </div>
            </div>
          </ScrollReveal>
        </div>

        <div class="lg:col-span-7">
          <ScrollReveal delay={100} direction="left">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 p-6 relative overflow-hidden">
              <!-- Decorative -->
              <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-[var(--color-accent)]/5 to-transparent rounded-bl-full pointer-events-none"></div>
              
              <div class="relative">
                <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">PROJECT INQUIRY</div>
                <h2 class="display-md mt-2">Fast request form</h2>

                <form id="contact-form" class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <label class="sm:col-span-1">
                    <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono); margin-bottom: 6px;">Your name</div>
                    <input
                      name="name"
                      required
                      type="text"
                      class="w-full h-10 rounded-[var(--radius-sm)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-3 text-[14px] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/50 focus:border-[var(--color-accent)] transition-all duration-200"
                      placeholder="Name"
                    />
                  </label>

                  <label class="sm:col-span-1">
                    <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono); margin-bottom: 6px;">Phone / Email</div>
                    <input
                      name="contact"
                      required
                      type="text"
                      class="w-full h-10 rounded-[var(--radius-sm)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-3 text-[14px] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/50 focus:border-[var(--color-accent)] transition-all duration-200"
                      placeholder="Phone or email"
                    />
                  </label>

                  <label class="sm:col-span-2">
                    <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono); margin-bottom: 6px;">Service</div>
                    <select
                      name="service"
                      class="w-full h-10 rounded-[var(--radius-sm)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-3 text-[14px] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/50 focus:border-[var(--color-accent)] transition-all duration-200"
                    >
                      {services.map((s) => (
                        <option value={s.value}>{s.label}</option>
                      ))}
                    </select>
                  </label>

                  <label class="sm:col-span-2">
                    <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono); margin-bottom: 6px;">Requirements</div>
                    <textarea
                      name="requirements"
                      required
                      rows="6"
                      class="w-full rounded-[var(--radius-sm)] border border-[var(--hairline)] bg-[var(--canvas-soft)] px-3 py-2 text-[14px] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/50 focus:border-[var(--color-accent)] transition-all duration-200 resize-none"
                      placeholder="What do you need? Reports, modules, workflows, users..."
                    ></textarea>
                  </label>

                  <div class="sm:col-span-2">
                    <button
                      type="submit"
                      class="group inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition-all duration-200"
                    >
                      Submit request
                      <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                      </svg>
                    </button>
                  </div>

                  <div id="form-success" class="hidden sm:col-span-2 rounded-[var(--radius-lg)] border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/5 p-4 text-[14px] text-[var(--color-accent)]">
                    ✓ Request captured (mock). We'll contact you shortly.
                  </div>
                </form>
              </div>
            </div>
          </ScrollReveal>

          <script is:inline>
            const form = document.getElementById('contact-form');
            const success = document.getElementById('form-success');
            form?.addEventListener('submit', (e) => {
              e.preventDefault();
              if (success) {
                success.classList.remove('hidden');
                success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            });
          </script>
        </div>
      </div>
    </div>
  </section>
</Layout>
