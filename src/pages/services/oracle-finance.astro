---
import Layout from '../../layouts/Layout.astro';
import ServiceWorkflowPreview from '../../components/ServiceWorkflowPreview.astro';
import GenAIGuardrails from '../../components/GenAIGuardrails.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

const reportCards = [
  { title: 'Account Statement', desc: 'Daily-to-monthly statements mapped to your master data and ledger rules.', img: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=600&h=280&fit=crop' },
  { title: 'Trial Balance', desc: 'Accurate TB generation with controlled heads and consistent totals.', img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop' },
  { title: 'Level-3 Head Reports', desc: 'Management-ready drill-down reports with role-based access.', img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=280&fit=crop' },
  { title: 'Cash / Bank Payment & Receipt', desc: 'Workflow entries with audit trail and report-ready outputs.', img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=280&fit=crop' },
];

const financeModules = [
  { name: 'Finance accounts', desc: 'Core ledger and account management', img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=320&fit=crop' },
  { name: 'Account statement', desc: 'Daily-to-monthly statement generation', img: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&h=320&fit=crop' },
  { name: 'Trial balance', desc: 'Controlled heads and consistent totals', img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=320&fit=crop' },
  { name: 'Account journal book', desc: 'Journal entries with audit trails', img: 'https://images.unsplash.com/photo-1568992687947-868a62a9f521?w=800&h=320&fit=crop' },
  { name: 'Level-3 head reports', desc: 'Management-ready drill-down reports', img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=320&fit=crop' },
  { name: 'Cash payment & receipt', desc: 'Cash workflow with report outputs', img: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&h=320&fit=crop' },
  { name: 'Bank payment & receipt', desc: 'Bank transaction tracking and reporting', img: 'https://images.unsplash.com/photo-1601597111158-2fceff292cdc?w=800&h=320&fit=crop' },
];

---

<Layout title="O-Tech Solutions | Oracle PL/SQL Finance" description="Oracle PL/SQL database software for finance accounts, statements, trial balance, journals, level-3 head reports, and cash/bank payment & receipt.">
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
          <div class="relative h-64 lg:h-auto overflow-hidden">
            <OptimizedImage
              src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop"
              alt="Oracle PL/SQL finance database"
              loading="eager"
              width={800}
              height={600}
              class="w-full h-full"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[var(--canvas)] via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-transparent lg:to-[var(--canvas)]"></div>
          </div>
          <div class="p-8 lg:p-12 flex items-center">
            <div class="max-w-[500px]">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                ORACLE PL/SQL DATABASE SOFTWARE
              </div>
              <h1 class="display-lg mt-2">Finance accounts & ERP reports (Oracle)</h1>
              <p class="mt-4 text-[16px] leading-[24px] text-[var(--body)] max-w-[88ch]">
                We develop Oracle-based PL/SQL modules for finance workflows and reporting—built with correctness-first
                logic and production-ready output formats.
              </p>
            </div>
          </div>
        </div>
      </div>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          <div class="lg:col-span-7">
            <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                MODULES
              </div>

              <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
              {financeModules.map((m) => (
                  <div class="group rounded-[var(--radius-md)] border border-[var(--hairline)] bg-[var(--canvas)] overflow-hidden">
                    <div class="relative h-24 overflow-hidden">
                      <OptimizedImage
                        src={m.img}
                        alt={m.name}
                        loading="eager"
                        width={600}
                        height={280}
                        class="w-full h-full transition-transform duration-700 ease-out group-hover:scale-110"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas)] via-[var(--canvas)]/40 to-transparent"></div>
                    </div>
                    <div class="px-4 py-3">
                      <div class="text-[13px] font-semibold text-[var(--ink)]">{m.name}</div>
                      <div class="mt-1 text-[11px] text-[var(--body)]">{m.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                REPORT OUTPUT
              </div>
              <div class="mt-4 space-y-3">
                {reportCards.map((c) => (
                  <div class="group rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] overflow-hidden">
                    <div class="relative h-28 overflow-hidden">
                      <OptimizedImage
                        src={c.img}
                        alt={c.title}
                        loading="eager"
                        width={600}
                        height={280}
                        class="w-full h-full transition-transform duration-700 ease-out group-hover:scale-110"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas-soft)] via-[var(--canvas-soft)]/40 to-transparent"></div>
                    </div>
                    <div class="p-4">
                      <div class="text-[14px] font-semibold text-[var(--ink)]">{c.title}</div>
                      <div class="mt-2 text-[13px] leading-[18px] text-[var(--body)]">{c.desc}</div>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-6">
                <a
                  href="/contact"
                  class="inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition"
                >
                  Request Oracle finance development →
                </a>
                <div class="mt-3 text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">
                  Hand-delivered process with UAT + delivery support.
                </div>
              </div>
            </div>
          </div>
        </div>

        <ServiceWorkflowPreview
          serviceBadge="DELIVERY WORKFLOW"
          title="Finance workflow preview (what you’ll see)"
          ctaText="Request Oracle finance development →"
          onRequestHref="/contact"
          scenarioCards={[
            { k: 'Modules', v: 'Ledger/account setup → accounts → statements → TB.' },
            { k: 'Role rights', v: 'Operator vs management access with report drill-down.' },
            { k: 'UAT + outputs', v: 'UAT on your chart of accounts + report-ready consistency.' },
          ]}
        />

        <GenAIGuardrails
          title="GEN-AI guardrails (safe automation)"
          note="AI supports drafting and summaries—never bypassing ledger rules or approval steps."
        />
      </div>
    </div>
  </section>
</Layout>
