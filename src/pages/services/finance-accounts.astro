---
import Layout from '../../layouts/Layout.astro';
import ServiceWorkflowPreview from '../../components/ServiceWorkflowPreview.astro';
import GenAIGuardrails from '../../components/GenAIGuardrails.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

const stockModules = [
  { title: 'Yarn Stock', desc: 'Track yarn inventory with accuracy for planning and accounting.', img: 'https://plus.unsplash.com/premium_photo-1661458017498-02c19c7eeac2?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1yZWxhdGVkfDE3fHx8ZW58MHx8fHx8' },
  { title: 'Sizing Bills', desc: 'Manage sizing workflows and billing output (mock).', img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=320&fit=crop' },
  { title: 'Sales Taxes Invoice', desc: 'Invoice generation with structured outputs (mock).', img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=320&fit=crop' },
  { title: 'User Rights Control', desc: 'Role-based access and operational workflows (mock).', img: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=320&fit=crop' },
  { title: 'Kachi & Pakki Parchi', desc: 'Inward/outward notes with ledger mapping (mock).', img: 'https://images.unsplash.com/photo-1568992687947-868a62a9f521?w=800&h=320&fit=crop' },
];

const outcomes = [
  'Cleaner invoice + report cycles',
  'Operational controls with user-based permissions',
  'Reports aligned to daily usage',
];
---

<Layout title="O-Tech Solutions | Finance & Accounts Management" description="Finance & accounts management: yarn stock, sizing bills, sales tax invoices, user rights, kachi & pakki parchi (inward/outward).">
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
          <div class="relative h-64 lg:h-auto overflow-hidden">
            <OptimizedImage
              src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&h=600&fit=crop"
              alt="Finance and accounts management"
              loading="eager"
              width={800}
              height={600}
              class="w-full h-full"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[var(--canvas)] via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-transparent lg:to-[var(--canvas)]"></div>
          </div>
          <div class="p-8 lg:p-12 flex items-center">
            <div class="max-w-[500px]">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                FINANCE & ACCOUNTS
              </div>
              <h1 class="display-lg mt-2">Yarn stock, invoices, user rights, Kachi/Pakki Parchi</h1>
              <p class="mt-4 text-[16px] leading-[24px] text-[var(--body)] max-w-[90ch]">
                Hand-delivered accounts management workflows built around permissions, inward/outward flows, and report-ready output.
              </p>
            </div>
          </div>
        </div>
      </div>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          <div class="lg:col-span-7">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {stockModules.map((m) => (
                <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] overflow-hidden">
                  <div class="relative h-28 overflow-hidden">
                    <OptimizedImage
                      src={m.img}
                      alt={m.title}
                      loading="eager"
                      width={400}
                      height={250}
                      class="w-full h-full"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas-soft)] via-transparent to-transparent"></div>
                  </div>
                  <div class="p-5">
                    <div class="text-[14px] font-semibold text-[var(--ink)]">{m.title}</div>
                    <div class="mt-2 text-[13px] leading-[18px] text-[var(--body)]">{m.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                BUSINESS OUTCOMES
              </div>

              <div class="relative mt-4 h-32 overflow-hidden rounded-[var(--radius-lg)] mb-4">
                <OptimizedImage
                  src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&h=300&fit=crop"
                  alt="Finance outcomes dashboard"
                  loading="eager"
                  width={600}
                  height={300}
                  class="w-full h-full"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas)] via-transparent to-transparent"></div>
              </div>

              <ul class="mt-4 space-y-3">
                {outcomes.map((o) => (
                  <li class="flex gap-3 items-start text-[14px] leading-[20px] text-[var(--body)]">
                    <span class="mt-1 inline-flex w-5 h-5 items-center justify-center rounded-full bg-[var(--canvas-soft)] border border-[var(--hairline)]">✓</span>
                    <span>{o}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6">
                <a href="/contact" class="inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition">
                  Request finance & accounts →
                </a>
                <div class="mt-3 text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">
                  Hand-delivered with UAT and operational reporting.
                </div>
              </div>
            </div>
          </div>
        </div>

        <ServiceWorkflowPreview
          serviceBadge="DELIVERY WORKFLOW"
          title="Finance & accounts workflow preview (what you’ll see)"
          ctaText="Request finance & accounts →"
          onRequestHref="/contact"
          scenarioCards={[
            { k: 'Modules', v: 'Yarn stock → invoices → inward/outward notes (Kachi/Pakki).' },
            { k: 'Role rights', v: 'User-based permissions for clean operations and controls.' },
            { k: 'UAT + outputs', v: 'UAT on your scenarios + report-ready output cycles.' },
          ]}
        />

        <GenAIGuardrails
          title="GEN-AI guardrails (safe automation)"
          note="AI drafts summaries and notes—but accounting correctness stays controlled and reviewed."
        />
      </div>
    </div>
  </section>
</Layout>
