---
import Layout from '../../layouts/Layout.astro';
import ServiceWorkflowPreview from '../../components/ServiceWorkflowPreview.astro';
import GenAIGuardrails from '../../components/GenAIGuardrails.astro';

const travelModules = [
  { title: 'Bookings & Itinerary', desc: 'Create bookings, manage itineraries, and track operational status.' },
  { title: 'Payments & Invoices', desc: 'Output structured invoices and finance-ready summaries (mock).' },
  { title: 'User Rights & Roles', desc: 'Role-based access for agents, supervisors, and admins (mock).' },
  { title: 'Operational Reports', desc: 'Daily reports aligned to real agency workflows (mock).' },
];

const delivery = [
  'Data mapping + UAT',
  'Role-based rights model',
  'Report outputs for management review',
];
---

<Layout title="O-Tech Solutions | Travel Agency Software" description="Travel agency ERP software for bookings, itineraries, payments, invoices, user rights, and operational reporting.">
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 p-8">
        <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
          TRAVEL AGENCY SOFTWARE
        </div>
        <h1 class="display-lg mt-2">Bookings ERP with invoices, roles, and reports</h1>
        <p class="mt-4 text-[16px] leading-[24px] text-[var(--body)] max-w-[90ch]">
          Hand-delivered software for travel workflows: bookings, itinerary operations, finance-ready outputs, and user rights.
        </p>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          <div class="lg:col-span-7">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {travelModules.map((m) => (
                <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-6">
                  <div class="text-[14px] font-semibold text-[var(--ink)]">{m.title}</div>
                  <div class="mt-2 text-[14px] leading-[20px] text-[var(--body)]">{m.desc}</div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                HOW WE DELIVER
              </div>

              <ul class="mt-4 space-y-3">
                {delivery.map((d) => (
                  <li class="flex gap-3 items-start text-[14px] leading-[20px] text-[var(--body)]">
                    <span class="mt-1 inline-flex w-5 h-5 items-center justify-center rounded-full bg-[var(--canvas-soft)] border border-[var(--hairline)]">✓</span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6">
                <a href="/contact" class="inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition">
                  Request travel ERP →
                </a>
                <div class="mt-3 text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">
                  Hand-delivered with UAT and support.
                </div>
              </div>
            </div>
          </div>
        </div>

        <ServiceWorkflowPreview
          serviceBadge="DELIVERY WORKFLOW"
          title="Travel workflow preview (what you’ll see)"
          ctaText="Request travel ERP →"
          onRequestHref="/contact"
          scenarioCards={[
            { k: 'Modules', v: 'Bookings → itineraries → payments/invoices.' },
            { k: 'Role rights', v: 'Agents vs supervisors/admin visibility boundaries.' },
            { k: 'UAT + outputs', v: 'UAT on real workflows + management-ready reports.' },
          ]}
        />

        <GenAIGuardrails
          title="GEN-AI guardrails (safe automation)"
          note="AI helps draft summaries and notes—final booking/invoice actions stay controlled."
        />
      </div>
    </div>
  </section>
</Layout>
