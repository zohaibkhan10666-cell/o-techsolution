---
import Layout from '../../layouts/Layout.astro';
import ServiceWorkflowPreview from '../../components/ServiceWorkflowPreview.astro';
import GenAIGuardrails from '../../components/GenAIGuardrails.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

const travelModules = [
  { title: 'Bookings & Itinerary', desc: 'Create bookings, manage itineraries, and track operational status.', img: 'https://media.istockphoto.com/id/175518669/photo/booking-button-virtual-keyboard.webp?a=1&b=1&s=612x612&w=0&k=20&c=jFQhH9Koe3Xu4uMFDiDu1hICM9cEr_FkEo9YCP-U5_4=' },
  { title: 'Payments & Invoices', desc: 'Output structured invoices and finance-ready summaries (mock).', img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=360&fit=crop' },
  { title: 'User Rights & Roles', desc: 'Role-based access for agents, supervisors, and admins (mock).', img: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=360&fit=crop' },
  { title: 'Operational Reports', desc: 'Daily reports aligned to real agency workflows (mock).', img: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=360&fit=crop' },
];

const delivery = [
  'Data mapping + UAT',
  'Role-based rights model',
  'Report outputs for management review',
];
---

<Layout title="O-Tech Solutions | Travel Agency Software" description="Travel agency ERP software for bookings, itineraries, payments, invoices, user rights, and operational reporting.">
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
          <div class="relative h-64 lg:h-auto overflow-hidden">
            <OptimizedImage
              src="https://media.istockphoto.com/id/1393093359/photo/search-for-air-travel-information-air-ticket-booking-for-travel.webp?a=1&b=1&s=612x612&w=0&k=20&c=niFwTbyQkgE_MqTAuGJR0DkU2urd3lFY4d5Lzvg336A="
              alt="Travel agency software"
              loading="eager"
              width={800}
              height={600}
              class="w-full h-full"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[var(--canvas)] via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-transparent lg:to-[var(--canvas)]"></div>
          </div>
          <div class="p-8 lg:p-12 flex items-center">
            <div class="max-w-[500px]">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                TRAVEL AGENCY SOFTWARE
              </div>
              <h1 class="display-lg mt-2">Bookings ERP with invoices, roles, and reports</h1>
              <p class="mt-4 text-[16px] leading-[24px] text-[var(--body)] max-w-[90ch]">
                Hand-delivered software for travel workflows: bookings, itinerary operations, finance-ready outputs, and user rights.
              </p>
            </div>
          </div>
        </div>
      </div>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          <div class="lg:col-span-7">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {travelModules.map((m) => (
                <div class="group rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] overflow-hidden">
                  <div class="relative h-36 overflow-hidden">
                    <OptimizedImage
                      src={m.img}
                      alt={m.title}
                      loading="eager"
                      width={600}
                      height={300}
                      class="w-full h-full transition-transform duration-700 ease-out group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas-soft)] via-[var(--canvas-soft)]/30 to-transparent"></div>
                  </div>
                  <div class="p-5">
                    <div class="text-[14px] font-semibold text-[var(--ink)]">{m.title}</div>
                    <div class="mt-2 text-[13px] leading-[18px] text-[var(--body)]">{m.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                HOW WE DELIVER
              </div>

              <div class="relative mt-4 h-36 overflow-hidden rounded-[var(--radius-lg)] mb-4">
                <OptimizedImage
                  src="https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=700&h=350&fit=crop"
                  alt="Travel operations workflow"
                  loading="eager"
                  width={700}
                  height={350}
                  class="w-full h-full"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--canvas)] via-transparent to-transparent"></div>
              </div>

              <ul class="mt-4 space-y-3">
                {delivery.map((d) => (
                  <li class="flex gap-3 items-start text-[14px] leading-[20px] text-[var(--body)]">
                    <span class="mt-1 inline-flex w-5 h-5 items-center justify-center rounded-full bg-[var(--canvas-soft)] border border-[var(--hairline)]">✓</span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6">
                <a href="/contact" class="inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition">
                  Request travel ERP →
                </a>
                <div class="mt-3 text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">
                  Hand-delivered with UAT and support.
                </div>
              </div>
            </div>
          </div>
        </div>

        <ServiceWorkflowPreview
          serviceBadge="DELIVERY WORKFLOW"
          title="Travel workflow preview (what you’ll see)"
          ctaText="Request travel ERP →"
          onRequestHref="/contact"
          scenarioCards={[
            { k: 'Modules', v: 'Bookings → itineraries → payments/invoices.' },
            { k: 'Role rights', v: 'Agents vs supervisors/admin visibility boundaries.' },
            { k: 'UAT + outputs', v: 'UAT on real workflows + management-ready reports.' },
          ]}
        />

        <GenAIGuardrails
          title="GEN-AI guardrails (safe automation)"
          note="AI helps draft summaries and notes—final booking/invoice actions stay controlled."
        />
      </div>
    </div>
  </section>
</Layout>
