---
import Layout from '../../layouts/Layout.astro';
import ServiceWorkflowPreview from '../../components/ServiceWorkflowPreview.astro';
import GenAIGuardrails from '../../components/GenAIGuardrails.astro';

const features = [
  { title: 'Grey Fabric Management', desc: 'Track batches, widths, weights, and production status across stages.' },
  { title: 'Print Cutting', desc: 'Cutting workflow with traceable output mapped to orders and lots.' },
  { title: 'Trading Management', desc: 'Trade movement tracking with report-ready summaries.' },
  { title: 'Parts Management System', desc: 'Manage parts, usage history, and availability for operations.' },
];

const deliveryNotes = [
  'Data mapping + UAT with factory workflows.',
  'Role-based access patterns for operators & supervisors.',
  'Report outputs built for daily decision-making.',
];

---
<Layout title="O-Tech Solutions | Weaving Software" description="Weaving/textile ERP software for grey fabric management, print cutting, trading management, and parts management.">
  <section class="py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl4 p-8">
        <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
          WEAVING / TEXTILE ERP
        </div>
        <h1 class="display-lg mt-2">Grey fabric + cutting + trading + parts management</h1>
        <p class="mt-4 text-[16px] leading-[24px] text-[var(--body)] max-w-[90ch]">
          Hand-delivered textile ERP modules built for real operations—so production, cutting, trading, and parts stay connected
          with accurate reporting.
        </p>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          <div class="lg:col-span-7">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {features.map((f) => (
                <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-6">
                  <div class="text-[14px] font-semibold text-[var(--ink)]">{f.title}</div>
                  <div class="mt-2 text-[14px] leading-[20px] text-[var(--body)]">{f.desc}</div>
                </div>
              ))}
            </div>

            <div class="mt-6 rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                TYPICAL DELIVERY
              </div>
              <ul class="mt-4 space-y-3">
                {deliveryNotes.map((d) => (
                  <li class="flex gap-3 items-start text-[14px] leading-[20px] text-[var(--body)]">
                    <span class="mt-1 inline-flex w-5 h-5 items-center justify-center rounded-full bg-[var(--canvas)] border border-[var(--hairline)]">✓</span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
            </div>

            <ServiceWorkflowPreview
              serviceBadge="DELIVERY WORKFLOW"
              title="Weaving workflow preview (what you’ll see)"
              ctaText="Request weaving ERP →"
              onRequestHref="/contact"
              scenarioCards={[
                { k: 'Modules', v: 'Batches → cutting → trading → parts flows.' },
                { k: 'Role rights', v: 'Operator vs supervisor access with traceable outputs.' },
                { k: 'UAT + outputs', v: 'UAT on real scenarios + daily decision reports.' },
              ]}
            />
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-[var(--radius-xl)] border border-[var(--hairline)] bg-[var(--canvas)] shadow-lvl3 p-6">
              <div class="text-[12px] text-[var(--mute)] uppercase tracking-wide" style="font-family: var(--font-mono);">
                ERP OUTPUTS
              </div>

              <div class="mt-4 space-y-3">
                {[
                  { k: 'Batch status reports', v: 'Real-time production visibility (mock)' },
                  { k: 'Cutting & dispatch summary', v: 'Daily reporting for supervisors (mock)' },
                  { k: 'Trading movement logs', v: 'Traceable trade history (mock)' },
                ].map((x) => (
                  <div class="rounded-[var(--radius-lg)] border border-[var(--hairline)] bg-[var(--canvas-soft)] p-4">
                    <div class="text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">{x.k}</div>
                    <div class="mt-2 text-[14px] font-semibold text-[var(--ink)]">{x.v}</div>
                  </div>
                ))}
              </div>

              <div class="mt-6">
                <a href="/contact" class="inline-flex items-center justify-center w-full h-12 px-7 rounded-[var(--radius-pill)] bg-[var(--primary)] text-[var(--on-primary)] text-[14px] font-semibold hover:opacity-95 transition">
                  Request weaving ERP →
                </a>
                <div class="mt-3 text-[12px] text-[var(--mute)]" style="font-family: var(--font-mono);">
                  Hand-delivered with UAT & delivery support.
                </div>
              </div>
            </div>

            <GenAIGuardrails
              title="GEN-AI guardrails (safe automation)"
              note="Use GEN-AI to summarize workflows and draft reports—never replacing the control steps that make ERP reliable."
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
